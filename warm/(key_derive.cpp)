#include <emscripten.h>
#include <cstdint>
#include <cstring>

extern "C" {
    // 导入JavaScript函数
    extern void consoleLog(int ptr, int len);
    
    // 导出函数：输入种子字符串，返回32字节密钥
    EMSCRIPTEN_KEEPALIVE
    void deriveKey(const char* seed, uint8_t* output) {
        size_t len = strlen(seed);
        uint32_t hash = 0x811c9dc5;
        
        // FNV-1a哈希
        for (size_t i = 0; i < len; i++) {
            hash ^= seed[i];
            hash *= 0x01000193;
        }
        
        // 扩展为32字节
        for (int i = 0; i < 32; i++) {
            output[i] = (hash >> (i % 4 * 8)) & 0xff;
            hash = (hash * 0x9e3779b9) ^ (hash >> 16);
        }
    }
    
    // 辅助调试函数
    EMSCRIPTEN_KEEPALIVE
    void logMessage(const char* msg) {
        int len = strlen(msg);
        consoleLog((int)msg, len);
    }
}